generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  bio             String?
  role            UserRole  @default(USER)
  favoriteArtists    String[]
  favoriteArtistIds  Artist[]  @relation("UserFavoriteArtists")
  accounts           Account[]
  sessions        Session[]
  createdGroups   Group[]       @relation("CreatedGroups")
  groupMemberships GroupMember[]
  posts           Post[]        @relation("UserPosts")
  postLikes       PostLike[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Artist {
  id          String    @id @default(cuid())
  name        String
  koreanName  String?
  slug        String    @unique
  type        String    @default("group") // "group" | "solo"
  company     String?
  description String?   @db.Text
  image       String?
  debutDate   DateTime?
  country     String?   @default("KR")
  genres      String[]
  socialLinks Json?
  externalIds Json?
  memberCount Int?
  groups      Group[]
  concerts    Concert[] @relation("ConcertArtists")
  favoritedBy User[]    @relation("UserFavoriteArtists")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  image       String?
  artistId    String?
  artist      Artist?       @relation(fields: [artistId], references: [id], onDelete: SetNull)
  isOfficial  Boolean       @default(false)
  createdById String
  createdBy   User          @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]
  posts       Post[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role     String   @default("member") // "admin" or "member"
  joinedAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Post {
  id        String     @id @default(cuid())
  content   String     @db.Text
  imageUrl  String?
  linkUrl   String?
  authorId  String
  author    User       @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Post?      @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Post[]     @relation("PostReplies")
  likes     PostLike[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Venue {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  city        String
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  capacity    Int?
  type        String?   // "arena" | "stadium" | "theater" | "convention_center"
  address     String?
  imageUrl    String?
  timezone    String?
  externalIds Json?
  concerts    Concert[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Concert {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  tourName     String?
  date         DateTime
  endDate      DateTime?
  doorsOpen    DateTime?
  status       String    @default("scheduled") // "scheduled" | "on_sale" | "sold_out" | "cancelled" | "postponed" | "completed"
  ticketUrl    String?
  priceRange   Json?
  imageUrl     String?
  description  String?   @db.Text
  eventType    String    @default("concert") // "concert" | "fan_meeting" | "festival" | "showcase"
  externalIds  Json?
  venueId      String
  venue        Venue     @relation(fields: [venueId], references: [id])
  artists      Artist[]  @relation("ConcertArtists")
  source       String?
  sourceUrl    String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([date])
  @@index([status])
  @@index([venueId])
}

// --- Scraper tracking & admin models ---

enum ScraperRunStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum AlertType {
  MISSING_FIELD
  DUPLICATE
  STALE_DATA
  INCONSISTENCY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ScraperRun {
  id             String           @id @default(cuid())
  scraperName    String
  status         ScraperRunStatus @default(RUNNING)
  startedAt      DateTime         @default(now())
  finishedAt     DateTime?
  recordsCreated Int              @default(0)
  recordsUpdated Int              @default(0)
  recordsFailed  Int              @default(0)
  errorMessage   String?          @db.Text
  logs           ScraperLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([scraperName])
  @@index([status])
  @@index([startedAt])
}

model ScraperLog {
  id           String     @id @default(cuid())
  scraperRunId String
  scraperRun   ScraperRun @relation(fields: [scraperRunId], references: [id], onDelete: Cascade)
  level        LogLevel
  message      String     @db.Text
  metadata     Json?
  createdAt    DateTime   @default(now())

  @@index([scraperRunId])
  @@index([level])
}

model DataQualityAlert {
  id         String        @id @default(cuid())
  alertType  AlertType
  severity   AlertSeverity
  entityType String
  entityId   String
  message    String        @db.Text
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([alertType])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([resolvedAt])
}
