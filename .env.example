# Database
# On Railway: add a PostgreSQL service and DATABASE_URL is injected automatically
DATABASE_URL="postgresql://user:password@localhost:5432/kpop_social_space?schema=public"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# NextAuth
AUTH_SECRET="generate-with-npx-auth-secret"
# On Railway: set AUTH_URL to your Railway public domain, e.g. https://your-app.up.railway.app
AUTH_URL="http://localhost:3000"

# OAuth Providers (configure at least one)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
