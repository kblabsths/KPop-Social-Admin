# Database
# On Railway: add a PostgreSQL service and DATABASE_URL is injected automatically
DATABASE_URL="postgresql://user:password@localhost:5432/kpop_social_space?schema=public"

# Supabase
# SUPABASE_URL is server-side only (no NEXT_PUBLIC_ prefix) — used by the service-role client
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# NextAuth
AUTH_SECRET="generate-with-npx-auth-secret"
# On Railway: set AUTH_URL to your Railway public domain, e.g. https://your-app.up.railway.app
AUTH_URL="http://localhost:3000"

# OAuth Providers
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
